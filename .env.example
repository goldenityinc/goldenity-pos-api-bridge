JWT_SECRET=samakan_dengan_secret_core_api
JWT_EXPIRES_IN=7d
PORT=3000

# URL database target untuk reset script Prisma
# Contoh: postgresql://user:password@host:5432/db_tpp?sslmode=require
DATABASE_URL=

# Alternatif khusus db_tpp (opsional)
DATABASE_URL_TPP=

# S3-Compatible Object Storage (Railway)
# Required for /storage/upload and media persistence.
STORAGE_ENDPOINT=
STORAGE_REGION=auto
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# Optional: public base URL for CDN/proxy if different from STORAGE_ENDPOINT.
STORAGE_PUBLIC_BASE_URL=

# Admin core callback for accounting auto-post (bridge -> admin-core)
ADMIN_CORE_API_BASE_URL=http://localhost:5000
ADMIN_CORE_INTERNAL_TOKEN=
ADMIN_CORE_API_TIMEOUT_MS=5000
