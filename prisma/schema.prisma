generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PettyCashDirection {
  IN
  OUT
}

/// The `tenants` table is OWNED by goldenity-admin-core-api.
/// @@ignore tells Prisma: "table exists in DB, do NOT manage or drop it from bridge."
model Tenant {
  id   String  @id
  slug String? @unique

  @@map("tenants")
  @@ignore
}

model Product {
  id            String    @id @default(cuid())
  tenantId      String    @map("tenant_id")
  name          String
  barcode       String?
  category      String?
  price         Float     @default(0)
  purchasePrice Float?    @map("purchase_price")
  stock         Int       @default(0)
  isService     Boolean   @default(false) @map("is_service")
  supplierName  String?   @map("supplier_name")
  imageUrl      String?   @map("image_url")
  isActive      Boolean?  @default(true) @map("is_active")
  createdAt     DateTime? @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("products")
}

model Customer {
  id         Int       @id @default(autoincrement())
  tenantId   String    @map("tenant_id")
  name       String
  phone      String?
  totalSpent Float     @default(0) @map("total_spent")
  createdAt  DateTime? @default(now()) @map("created_at")
  updatedAt  DateTime? @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("customers")
}

/// Petty cash logs per tenant. tenantId stored as scalar (no FK to tenants table
/// since tenants table is managed by admin-core, not bridge).
model PettyCashLog {
  id        String             @id @default(uuid()) @db.Uuid
  tenantId  String             @map("tenant_id")
  userId    String?            @map("user_id")
  amount    Int
  type      PettyCashDirection @default(IN)
  notes     String?            @db.Text
  createdAt DateTime           @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@index([userId])
  @@map("petty_cash_logs")
}
